{
  "manifest_version": 3,
  "name": "Intervals.icu - JSON to Clipboard",
  "version": "0.0.2",
  "description": "Add a 'JSON to Clipboard' button to Intervals.icu to easily export activities.",
  "content_scripts": [
    {
      "matches": [
        "https://intervals.icu/activities/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}